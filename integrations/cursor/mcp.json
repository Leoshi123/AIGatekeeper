{
  "mcpServers": {
    "ag-wrapper": {
      "command": "python",
      "args": ["-m", "src.mcp_server"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  },
  "cursor": {
    "enabled": true,
    "blockOnCritical": true,
    "pruneContext": true,
    "sanitizeOnGenerate": true
  }
}